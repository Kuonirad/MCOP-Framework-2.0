{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MCOP Desktop",
  "version": "2.4.0",
  "identifier": "ai.kullabs.mcop",
  "build": {
    "beforeDevCommand": "pnpm --dir ../.. dev",
    "devUrl": "http://127.0.0.1:3000/desktop",
    "beforeBuildCommand": "pnpm --dir ../.. desktop:prepare",
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MCOP Desktop",
        "url": "index.html",
        "width": 1440,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 680,
        "maximized": true,
        "decorations": false,
        "resizable": true,
        "shadow": true,
        "theme": "Dark",
        "backgroundColor": "#02040b"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Deterministic, auditable AI orchestration",
    "longDescription": "A native product shell for MCOP's motion-glass interface, Dialectical Studio, cinematic showcase, and local deterministic triad runtime.",
    "copyright": "Copyright KullAI Labs",
    "externalBin": [
      "binaries/node"
    ],
    "resources": [
      "resources/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "mcop"
        ]
      }
    }
  }
}
