{
  "name": "@kuonirad/mcop-framework",
  "version": "0.1.0",
  "private": true,
  "license": "BUSL-1.1",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --pretty",
    "typecheck:watch": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ssr-lcp": "node scripts/verify-ssr-lcp.mjs",
    "postinstall": "cypress install || true",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:hybrid": "concurrently --kill-others-on-fail --names jest,cypress,playwright \"pnpm test\" \"pnpm cypress:run\" \"if [ \\\"$PLAYWRIGHT_ENABLED\\\" = '1' ]; then pnpm exec playwright test; else echo 'playwright skipped (PLAYWRIGHT_ENABLED!=1)'; fi\"",
    "test:ci": "pnpm test && pnpm cypress:run && (if [ \"$PLAYWRIGHT_ENABLED\" = \"1\" ]; then pnpm exec playwright test; else echo 'playwright skipped (PLAYWRIGHT_ENABLED!=1)'; fi)",
    "deps:check": "pnpm outdated && pnpm audit --audit-level=moderate",
    "deps:audit": "pnpm audit --audit-level=moderate",
    "deps:update-check": "pnpm outdated",
    "eco:audit": "node scripts/eco-audit.mjs",
    "parity:check": "node scripts/parity-guardian.mjs",
    "triad:fingerprint": "node scripts/triad-fingerprint.mjs",
    "audit:placement": "node scripts/placement-linter.mjs",
    "baseline:stigmergy": "node scripts/baselines/stigmergyResonanceBaseline.mjs",
    "docs:guard": "node scripts/shared-docs-guard.mjs"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "canonicalize": "^3.0.0",
    "next": "16.2.4",
    "pino": "^10.1.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cypress": "^15.14.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "ajv@<6.14.0": "^6.14.0",
      "brace-expansion@1": "^1.1.13",
      "brace-expansion@2": "^2.0.3",
      "flatted@<3.4.2": "^3.4.2",
      "handlebars@<4.7.9": "^4.7.9",
      "minimatch@3": "^3.1.5",
      "minimatch@9": "^9.0.7",
      "picomatch@2": "^2.3.2",
      "picomatch@4": "^4.0.4",
      "postcss@<8.5.10": "^8.5.10",
      "uuid": "^14.0.0"
    }
  }
}
