{
  "name": "@kuonirad/mcop-framework",
  "version": "2.4.0",
  "private": true,
  "license": "Apache-2.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --pretty",
    "typecheck:watch": "tsc -p tsconfig.json --watch --preserveWhatchOutput",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ssr-lcp": "node scripts/verify-ssr-lcp.mjs",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm sbom && pnpm sbom:validate",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:hybrid": "concurrently --kill-others-on-fail --names jest,cypress,playwright \"pnpm test\" \"pnpm cypress:run\" \"if [ \\\"$PLAYWRIGHT_ENABLED\\\" = '1' ]; then pnpm exec playwright test; else echo 'playwright skipped (PLAYWRIGHT_ENABLED!=1)'; fi\"",
    "test:ci": "pnpm test && pnpm cypress:run && (if [ \"$PLAYWRIGHT_ENABLED\" = \"1\" ]; then pnpm exec playwright test; else echo 'playwright skipped (PLAYWRIGHT_ENABLED!=1)'; fi)",
    "deps:check": "pnpm outdated && npm audit --audit-level=high",
    "deps:audit": "npm audit --audit-level=high",
    "deps:update-check": "pnpm outdated",
    "eco:audit": "node scripts/eco-audit.mjs",
    "parity:check": "pnpm --filter @kullailabs/mcop-core build && node scripts/parity-guardian.mjs",
    "triad:fingerprint": "node scripts/triad-fingerprint.mjs",
    "audit:placement": "node scripts/placement-linter.mjs",
    "baseline:stigmergy": "node scripts/baselines/stigmergyResonanceBaseline.mjs",
    "docs:guard": "node scripts/shared-docs-guard.mjs",
    "typedoc": "pnpm --filter @kullailabs/mcop-core typedoc",
    "coverage:badge": "node scripts/coverage-badge.mjs",
    "benchmark:refresh": "BENCHMARK_GENERATE=1 jest --testPathPatterns=src/__tests__/benchmarks.test.ts",
    "preprint:fill": "node scripts/preprint-fill.mjs",
    "sbom": "node scripts/generate-sbom.mjs",
    "sbom:validate": "node scripts/validate-sbom.mjs",
    "positive:audit": "node scripts/positive-audit.mjs",
    "cluster:replay": "node scripts/run-cluster-replay-example.mjs",
    "positive:share": "node -e \"process.stdout.write(require('node:fs').readFileSync('docs/positive-impact-share.md','utf8'))\"",
    "audit:auditor-kernel": "node scripts/auditor-kernel-etch.mjs",
    "audit:velocity": "node scripts/velocity-auditor-etch.mjs",
    "positive:attest": "POSITIVE_IMPACT_ATTEST=1 jest --runInBand --testPathPatterns=positiveImpactVerifier",
    "positive:verify": "POSITIVE_IMPACT_VERIFY=1 jest --runInBand --testPathPatterns=positiveImpactVerifier",
    "positive:quality": "POSITIVE_IMPACT_QUALITY=1 jest --runInBand --testPathPatterns=verificationQuality",
    "efficacy:test": "jest --testPathPatterns='efficacyStatistics|interRaterReliability|efficacyProgram'",
    "control:test": "jest --testPathPatterns='pidController|fastControlLoop|proteomeControlPlant'",
    "temporal:test": "jest --testPathPatterns='temporalStigmergy|stigmergyTemporal'",
    "hotpath:test": "jest --testPathPatterns='hotPathParity|hotPathRouter'",
    "conformance:test": "jest --testPathPatterns='codeowners|approvedChangeset|conformanceSuite'",
    "changeset:gate": "MCOP_GATE=1 jest --runInBand --testPathPatterns=approvedChangesetGate.ci",
    "self:audit": "python scripts/self_audit.py",
    "benchmark:arc-evo": "node scripts/benchmark-arc-evo.mjs",
    "benchmark:arc-ls20": "node scripts/benchmark-arc-ls20.mjs --mode=full",
    "benchmark:arc-ls20:smoke": "node scripts/benchmark-arc-ls20.mjs --mode=smoke",
    "benchmark:cuda-graph": "node scripts/benchmark-cuda-graph.mjs --mode=full",
    "benchmark:cuda-graph:smoke": "node scripts/benchmark-cuda-graph.mjs --mode=smoke",
    "benchmark:cuda-ops": "node scripts/benchmark-cuda-graph.mjs --op=all --mode=full",
    "benchmark:cuda-ops:smoke": "node scripts/benchmark-cuda-graph.mjs --op=all --mode=smoke",
    "soak:cuda-verified-device": "node scripts/cuda-verified-device-soak.mjs --steps=1000 --mode=smoke",
    "soak:cuda-verified-device:canary": "node scripts/cuda-verified-device-soak.mjs --steps=1000 --canary=500 --mode=smoke",
    "cuda:serve": "python3 -m mcop_cuda_server --port 8765 --device cuda:0",
    "ledger:serve": "node --experimental-strip-types services/ledger/src/server.ts",
    "ledger:verify": "node scripts/mcop-ledger-verify.mjs",
    "pouw:verify": "node scripts/mcop-pouw-verify.mjs",
    "cuda:export-kernels": "python3 scripts/export_cuda_kernels/export.py --out-dir models --backend reference",
    "cuda:export-kernels:pytorch": "python3 scripts/export_cuda_kernels/export.py --out-dir models --backend pytorch --fp-variant fp16",
    "dev:cuda": "concurrently \"pnpm dev\" \"pnpm cuda:serve\"",
    "registry:telemetry": "node scripts/registry-telemetry.mjs --pretty",
    "ci:workflow-hygiene": "node scripts/verify-workflow-hygiene.mjs",
    "ci:pr-checklist": "node scripts/verify-pr-checklist.mjs",
    "audit:claims": "bash scripts/audit-repo-claims.sh",
    "audit:parp-baseline": "node scripts/parp-baseline.mjs",
    "docs:check": "node scripts/check-readme-code-blocks.mjs",
    "determinism:test": "node scripts/test-determinism.mjs",
    "bench:smoke": "node scripts/bench-smoke.mjs",
    "standalone:build": "pnpm build && node scripts/desktop/stage-standalone.mjs --output dist/standalone",
    "standalone:start": "node scripts/desktop/start-standalone.mjs --root dist/standalone",
    "desktop:test": "node --test scripts/desktop/*.node-tests.mjs",
    "desktop:prepare": "pnpm build && node scripts/desktop/stage-standalone.mjs --output apps/desktop/src-tauri/resources/server && node scripts/desktop/prepare-node-runtime.mjs",
    "desktop:dev": "pnpm --dir apps/desktop tauri dev",
    "desktop:build": "pnpm --dir apps/desktop tauri build"
  },
  "engines": {
    "node": ">=22.22.3 <25",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "canonicalize": "^3.0.0",
    "next": "15.5.18",
    "openai": "^6.37.0",
    "pino": "^10.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@cyclonedx/cdxgen": "^12.7.1",
    "@cyclonedx/cyclonedx-library": "^10",
    "@eslint/eslintrc": "^3.3.6",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "ajv": "^8",
    "ajv-formats": "^3",
    "ajv-formats-draft2019": "^1",
    "concurrently": "^9.2.1",
    "cypress": "^15.18.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "@lhci/cli": "0.15.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-environment-node": "^30.4.1",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.11",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "ajv@<6.14.0": "^6.14.0",
      "brace-expansion@1": "^1.1.13",
      "brace-expansion@2": "^2.0.3",
      "brace-expansion@5": "^5.0.6",
      "flatted@<3.4.2": "^3.4.2",
      "handlebars@<4.7.9": "^4.7.9",
      "minimatch@3": "^3.1.5",
      "minimatch@9": "^9.0.7",
      "picomatch@2": "^2.3.2",
      "picomatch@4": "^4.0.4",
      "postcss@<8.5.10": "^8.5.10",
      "systeminformation": "^5.31.6",
      "uuid": "^14.0.0",
      "fast-uri@<3.1.2": "^3.1.2",
      "cookie@<0.7.0": "^0.7.0",
      "tmp@<0.2.6": "^0.2.6",
      "markdown-it@<=14.1.1": "14.2.0",
      "js-yaml@<=4.1.1": "4.2.0",
      "@babel/core@<=7.29.0": "7.29.6",
      "form-data@>=4.0.0 <4.0.6": "4.0.6",
      "tar@<=7.5.15": "7.5.16",
      "ws@>=8.0.0 <8.21.0": "8.21.0",
      "qs@>=6.11.1 <6.15.2": "^6.15.2",
      "shell-quote@<1.8.4": "^1.8.4",
      "undici@<7.28.0": "7.28.0",
      "esbuild@>=0.17.0 <0.28.1": "^0.28.1"
    },
        "peerDependencyRules": {
                "allowedVersions": {
                          "ajv-formats-draft2019>ajv": "8"
                }
        }
  },
  "overrides": {
    "postcss": "^8.5.10",
    "fast-uri": "^3.1.2",
    "systeminformation": "^5.31.6",
    "brace-expansion@5": "^5.0.6",
    "markdown-it": "14.2.0",
    "js-yaml": "4.2.0",
    "@babel/core": "7.29.6",
    "form-data": "4.0.6",
    "tar": "7.5.16",
    "ws@8": "8.21.0",
    "cookie": "^0.7.0",
    "tmp": "^0.2.6",
    "uuid": "^14.0.0",
    "qs": "^6.15.2",
    "shell-quote": "^1.8.4",
    "undici": "7.28.0",
    "esbuild": "^0.28.1"
  },
  "keywords": [
    "arc-agi",
    "meta-cognitive",
    "evolutionary-ai"
  ]
}
