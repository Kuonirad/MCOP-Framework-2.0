{
  "name": "@kuonirad/mcop-framework",
  "version": "0.1.0",
  "private": true,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "deps:check": "pnpm outdated && pnpm audit --audit-level=moderate",
    "deps:audit": "pnpm audit --audit-level=moderate",
    "deps:update-check": "pnpm outdated",
    "eco:audit": "node scripts/eco-audit.mjs"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "next": "16.2.4",
    "pino": "^10.1.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "25.0.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "ajv@<6.14.0": "^6.14.0",
      "brace-expansion@1": "^1.1.13",
      "brace-expansion@2": "^2.0.3",
      "flatted@<3.4.2": "^3.4.2",
      "handlebars@<4.7.9": "^4.7.9",
      "minimatch@3": "^3.1.5",
      "minimatch@9": "^9.0.7",
      "picomatch@2": "^2.3.2",
      "picomatch@4": "^4.0.4"
    }
  }
