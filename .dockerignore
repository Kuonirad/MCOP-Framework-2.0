# Ignore everything
*

# Allow specific files for build context
!package.json
!pnpm-lock.yaml
!.npmrc
!next.config.ts
!tsconfig.json
!postcss.config.mjs
!eslint.config.mjs
!tailwind.config.ts

# Allow source directories
!src/
!public/
!components/
!lib/
!app/

# Allow data files imported at build time by the Next app.
# The /benchmarks page does `import results from "../../../docs/benchmarks/results.json"`,
# so the snapshot has to be in the build context. Markdown under docs/ stays excluded.
!docs/benchmarks/results.json

# Ignore within allowed directories
**/.DS_Store
**/*.log
**/*.env*
**/node_modules/
**/.next/
**/coverage/
**/artefacts/

# Ignore test files in production build
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/__tests__/
