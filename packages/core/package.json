{
  "name": "@kullailabs/mcop-core",
  "version": "0.1.1",
  "description": "MCOP (Meta-Cognitive Optimization Protocol) core primitives — deterministic, auditable, provenance-tracked reasoning: NOVA-NEO encoder, Stigmergy v5, Holographic Etch.",
  "keywords": [
    "mcop",
    "agent-memory",
    "provenance",
    "audit-log",
    "merkle",
    "cosine-similarity",
    "deterministic",
    "sha256",
    "ai",
    "llm"
  ],
  "author": "Kevin John Kull (Kuonirad)",
  "license": "BUSL-1.1",
  "homepage": "https://github.com/Kuonirad/MCOP-Framework-2.0#readme",
  "bugs": {
    "url": "https://github.com/Kuonirad/MCOP-Framework-2.0/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kuonirad/MCOP-Framework-2.0.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "NOTICE.md",
    "LICENSE-MIT-LEGACY"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "prepack": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit",
    "typedoc": "typedoc"
  },
  "dependencies": {
    "canonicalize": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typedoc": "^0.28.19",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  }
}
