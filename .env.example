# MCOP Framework 2.0 — environment template
# Copy to `.env` and adjust values for your environment.
# Never commit real secrets to the repository.
#
# SECURITY AUDIT 2026-05-01: Verified — this file contains NO real API keys,
# passwords, tokens, or credentials. All values are safe defaults / placeholders.
# If you add a new secret placeholder, document it here and ensure the real
# value lives only in `.env` (which is gitignored).

# ----- Runtime -----
NODE_ENV=development
PORT=3000

# ----- Logging (Pino) -----
# trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# ----- Triad configuration -----
# Fixed tensor dimension produced by NovaNeoEncoder.
MCOP_ENCODER_DIMENSIONS=64
# Normalize encoder output to unit length.
MCOP_ENCODER_NORMALIZE=true
# Minimum cosine similarity for a Stigmergy v5 resonance hit.
MCOP_STIGMERGY_RESONANCE_THRESHOLD=0.55

# ----- Docker -----
# Consumed by docker-compose when using override file for local mounts.
MCOP_IMAGE_TAG=latest
