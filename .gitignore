# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/.venv/
/node_modules
node_modules/
packages/*/node_modules/
packages/*/dist/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
cypress/screenshots/
cypress/videos/
cypress/downloads/

# generated API docs (TypeDoc)
docs/api/core/

# generated SBOMs (CycloneDX) — regenerated on each publish
docs/sbom/*.cdx.json

# next.js
/.next/
/out/

# production
/build
dist/
*.egg-info/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
